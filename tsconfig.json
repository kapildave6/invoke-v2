{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "types": ["node", "react"],
    "baseUrl": ".",
    "paths": {
      "@invoke/schema": ["schema/src/index.ts"],
      "@invoke/reconciler": ["runtime/reconciler/src/index.ts"],
      "@invoke/api": ["packages/api/src/index.ts"],
      "@invoke/utils": ["packages/utils/src/index.ts"],
      "@raycast/api": ["packages/compat-raycast/src/index.ts"]
    }
  },
  "include": ["schema/src", "packages/*/src", "runtime/*/src", "examples/*/src"]
}
