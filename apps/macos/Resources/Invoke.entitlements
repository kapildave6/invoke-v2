<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required so a hardened-runtime build can send Apple events (the runAppleScript capability
       drives Notes, etc.). Without this, macOS returns errAEEventNotPermitted (-1743) and never even
       shows the Automation prompt. -->
  <key>com.apple.security.automation.apple-events</key>
  <true/>
</dict>
</plist>
