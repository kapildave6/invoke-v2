{
  "name": "invoke-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Invoke — a keyboard-first command palette + extensible plugin platform (Raycast-style). See PLAN.md.",
  "type": "module",
  "workspaces": [
    "schema",
    "packages/api",
    "packages/utils",
    "packages/compat-raycast",
    "packages/compat-raycast-utils",
    "runtime/reconciler",
    "runtime/node-host",
    "examples/hacker-news",
    "examples/tech-radar",
    "examples/ui-gallery"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "demo": "tsx runtime/node-host/src/demo.ts",
    "dev:ext": "tsx runtime/node-host/src/run.ts",
    "import:ext": "tsx runtime/node-host/src/import.ts",
    "redteam": "tsx runtime/node-host/src/redteam.ts",
    "test:calc": "tsx examples/calculator/src/engine.test.ts",
    "typecheck": "tsc -p tsconfig.json",
    "clean": "rm -rf node_modules **/node_modules **/dist **/*.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-reconciler": "^0.28.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "date-fns": "^4.4.0",
    "lodash": "^4.18.1",
    "node-html-markdown": "^2.0.0",
    "pinyin-pro": "^3.28.1"
  }
}
